{
  "name": "@xndrjs/monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "generate": "plop --plopfile plop/plopfile.cjs --dest .",
    "sync-tsconfig-references": "tsx plop/scripts/sync-tsconfig-references.ts",
    "postinstall": "pnpm sync-tsconfig-references",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:node": "vitest run --project node",
    "test:react": "vitest run --project react",
    "lint-staged": "lint-staged",
    "mcp:plop": "tsx plop/mcp/server.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "node-plop": "^0.32.3",
    "plop": "^4.0.5",
    "prettier": "^3.8.3",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  }
}
